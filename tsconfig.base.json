{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "composite": true,
    "incremental": true,
    "paths": {
      "@truck-shipping/shared-types": ["./packages/shared-types/src/index.ts"],
      "@truck-shipping/shared-validators": ["./packages/shared-validators/src/index.ts"],
      "@truck-shipping/shared-utils": ["./packages/shared-utils/src/index.ts"],
      "@truck-shipping/database": ["./packages/database/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
