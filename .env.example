# ============================================================
# TruckShip Platform — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://truckship:password@localhost:5432/truckship_dev"
DATABASE_TEST_URL="postgresql://truckship:password@localhost:5432/truckship_test"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT Authentication ---
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-in-production-use-at-least-64-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Keycloak (optional — used in production) ---
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="truck-shipping"
KEYCLOAK_CLIENT_ID="api-gateway"
KEYCLOAK_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=""

# --- Firebase Cloud Messaging (Push Notifications) ---
FCM_SERVER_KEY=""
FIREBASE_PROJECT_ID=""

# --- SendGrid (Email) ---
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@truckship.com"
SENDGRID_FROM_NAME="TruckShip"

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- AWS S3 (Document Storage) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="truckship-documents-dev"

# --- Application ---
NODE_ENV="development"
PORT=3000
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
MATCHING_SERVICE_PORT=3002
DISPATCH_SERVICE_PORT=3003
TRACKING_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# --- CORS ---
WEB_APP_URL="http://localhost:3100"
ALLOWED_ORIGINS="http://localhost:3100,http://localhost:3000"

# --- Web App (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"

# --- Logging ---
LOG_LEVEL="debug"
