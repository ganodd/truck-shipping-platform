{
  "expo": {
    "name": "TruckShip",
    "slug": "truckship",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.truckship.driver",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TruckShip needs location access for real-time shipment tracking.",
        "NSLocationWhenInUseUsageDescription": "TruckShip needs location access for shipment tracking.",
        "NSCameraUsageDescription": "TruckShip needs camera access to capture proof-of-delivery photos.",
        "NSPhotoLibraryUsageDescription": "TruckShip needs photo library access to upload documents."
      },
      "backgroundModes": ["location", "fetch"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.truckship.driver",
      "versionCode": 1,
      "permissions": [
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TruckShip needs location access for real-time shipment tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb"
        }
      ]
    ],
    "scheme": "truckship",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
